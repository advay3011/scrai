# Backend API Configuration
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# GDELT API Configuration
GDELT_API_KEY=your-gdelt-api-key
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2

# NOAA (National Oceanic and Atmospheric Administration) API
NOAA_API_KEY=your-noaa-api-key
NOAA_BASE_URL=https://www.ncdc.noaa.gov/cdo-web/api/v2

# World Bank API Configuration
WORLD_BANK_API_KEY=your-world-bank-api-key
WORLD_BANK_BASE_URL=https://api.worldbank.org/v2

# OpenAI API (for AI-powered analysis)
OPENAI_API_KEY=your-openai-api-key

# Data Collection Schedule (cron format)
COLLECTOR_SCHEDULE=0 */6 * * *

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
